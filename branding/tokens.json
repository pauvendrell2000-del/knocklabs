{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "base":    { "$value": "#0D0D0D", "$type": "color", "$description": "Fondo oscuro principal" },
    "cream":   { "$value": "#F2F0EB", "$type": "color", "$description": "Fondo claro / texto sobre oscuro" },
    "accent":  { "$value": "#FF4C00", "$type": "color", "$description": "Color de acción principal" },
    "dark01":  { "$value": "#1A1A1A", "$type": "color", "$description": "Hover cards oscuras" },
    "dark02":  { "$value": "#2A2A2A", "$type": "color", "$description": "Bordes sobre oscuro" },
    "cream-placeholder": { "$value": "#EBE8E0", "$type": "color", "$description": "Placeholder de imagen" }
  },
  "opacity": {
    "cream-10": { "$value": "0.10" }, "cream-15": { "$value": "0.15" },
    "cream-20": { "$value": "0.20" }, "cream-25": { "$value": "0.25" },
    "cream-30": { "$value": "0.30" }, "cream-40": { "$value": "0.40" },
    "cream-50": { "$value": "0.50" }, "cream-60": { "$value": "0.60" },
    "base-06":  { "$value": "0.06" }, "base-08":  { "$value": "0.08" },
    "base-10":  { "$value": "0.10" }, "base-40":  { "$value": "0.40" },
    "base-50":  { "$value": "0.50" }, "base-60":  { "$value": "0.60" },
    "base-70":  { "$value": "0.70" }
  },
  "font": {
    "family-display": { "$value": "Archivo, sans-serif",     "$type": "fontFamily" },
    "family-mono":    { "$value": "DM Mono, monospace",      "$type": "fontFamily" },
    "weight-light":   { "$value": "300",                     "$type": "fontWeight" },
    "weight-regular": { "$value": "400",                     "$type": "fontWeight" },
    "weight-medium":  { "$value": "500",                     "$type": "fontWeight" },
    "weight-semibold":{ "$value": "600",                     "$type": "fontWeight" },
    "weight-black":   { "$value": "900",                     "$type": "fontWeight" }
  },
  "fontSize": {
    "display":     { "$value": "clamp(4rem, 12vw, 10rem)",     "$description": "Clase .display" },
    "hero":        { "$value": "clamp(3.5rem, 10vw, 9rem)",    "$description": "Hero page titles" },
    "h1":          { "$value": "clamp(3rem, 9vw, 8rem)",       "$description": "About / Work page" },
    "h2-xl":       { "$value": "clamp(2.5rem, 5vw, 4.5rem)",   "$description": "CTA sections" },
    "h2":          { "$value": "clamp(2rem, 3.5vw, 3rem)",     "$description": "Section headers" },
    "h3-card":     { "$value": "clamp(1.5rem, 2.2vw, 2rem)",   "$description": "Card titles" },
    "h3-detail":   { "$value": "clamp(1.35rem, 2vw, 1.75rem)", "$description": "Offering/step titles" },
    "body-xl":     { "$value": "1.25rem",                      "$description": "text-xl" },
    "body":        { "$value": "1rem",                         "$description": "text-base" },
    "body-sm":     { "$value": "0.875rem",                     "$description": "text-sm" },
    "badge":       { "$value": "clamp(0.75rem, 1vw, 0.9rem)",  "$description": "KNOCK badge" },
    "label":       { "$value": "clamp(0.65rem, 0.8vw, 0.75rem)","$description": ".section-label" },
    "mono":        { "$value": "0.75rem",                      "$description": "text-xs mono" },
    "mono-sm":     { "$value": "0.625rem",                     "$description": "text-[10px]" },
    "mono-xs":     { "$value": "0.5625rem",                    "$description": "text-[9px]" }
  },
  "letterSpacing": {
    "tight-6":    { "$value": "-0.06em",    "$description": "Badge, monogram" },
    "tight-4":    { "$value": "-0.04em",    "$description": "Hero detail titles" },
    "tight-35":   { "$value": "-0.035em",   "$description": "Display / section titles" },
    "tight-3":    { "$value": "-0.03em",    "$description": "H3 cards" },
    "tight-25":   { "$value": "-0.025em",   "$description": "Process steps" },
    "tight-2":    { "$value": "-0.02em",    "$description": "Nav links, buttons" },
    "tight-15":   { "$value": "-0.015em",   "$description": "Body large" },
    "tight-1":    { "$value": "-0.01em",    "$description": "Body regular" },
    "wide":       { "$value": "0.16em",     "$description": "Section labels" },
    "widest":     { "$value": "0.2em",      "$description": "Uppercase mono labels" }
  },
  "lineHeight": {
    "display":    { "$value": "0.88" },
    "heading-xl": { "$value": "0.9"  },
    "heading":    { "$value": "0.95" },
    "tight":      { "$value": "1.0"  },
    "snug":       { "$value": "1.05" },
    "card":       { "$value": "1.1"  },
    "metadata":   { "$value": "1.3"  },
    "body-lg":    { "$value": "1.4"  },
    "body":       { "$value": "1.625" }
  },
  "spacing": {
    "px-mobile":  { "$value": "24px",  "$description": "px-6" },
    "px-tablet":  { "$value": "32px",  "$description": "px-8" },
    "px-desktop": { "$value": "48px",  "$description": "px-12" },
    "py-section": { "$value": "96px",  "$description": "py-24 mobile" },
    "py-section-lg":{ "$value": "128px","$description": "py-32 desktop" },
    "max-width":  { "$value": "1920px", "$description": "Global wrapper" }
  },
  "borderRadius": {
    "none": { "$value": "0px", "$description": "Sharp corners everywhere" },
    "full": { "$value": "9999px", "$description": "Solo cursor dot / pulse dot" }
  },
  "easing": {
    "power3-inout": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$description": "Easing principal de Knock Labs" },
    "ease-out":     { "$value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)", "$description": "ScrollReveal" },
    "linear":       { "$value": "linear", "$description": "Loader text scroll" }
  },
  "duration": {
    "micro":   { "$value": "150ms" },
    "fast":    { "$value": "200ms" },
    "base":    { "$value": "300ms" },
    "medium":  { "$value": "600ms" },
    "slow":    { "$value": "700ms" },
    "page":    { "$value": "900ms" },
    "hero":    { "$value": "1000ms" },
    "loader":  { "$value": "1200ms" }
  },
  "shadow": {
    "none": { "$value": "none", "$description": "Sin sombras — diseño plano" }
  }
}
